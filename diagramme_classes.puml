' ==================================================================
' PACKAGE CONTROLLEUR
' ==================================================================
package "controlleur" #E8F5E9 {

    enum "Controleur.ModeAction" as ModeAction {
        DEPLACEMENT
        CREUSER
        EXPLORER
        RAMASSER
        DONNER_EAU
        PRENDRE_EAU
        ATTENTE
        UTILISER_EQUIPEMENT
    }

    class Controleur <<PlateauListener, ActionListener>> {
        - modele : Desert
        - fenetre : Fenetre
        - modeActuel : ModeAction
        - joueurCible : Joueur
        --
        + Controleur(Desert, Fenetre)
        - initialiserEcouteursBoutons() : void
        - enregistrerObservateurs() : void
        + zoneCliquee(int, int) : void
        + actionPerformed(ActionEvent) : void
        - effectuerDeplacement(int, int) : void
        - effectuerCreusage(int, int) : void
        - effectuerExploration(int, int) : void
        - effectuerRamassage(int, int) : void
        - selectionnerJoueurPourEau(int, int) : void
        - effectuerUtilisationEquipementSurZone(int, int) : void
        - verifierActionsDisponibles() : void
        - surlignerZonesAccessibles() : void
        - surlignerZonesCreusables() : void
        - ouvrirDialogueEquipement() : void
        - verifierActionsRestantes() : void
        - finDeTour() : void
        - retournerAuMenu() : void
        - lancerPartieDepuisMenu() : void
        + lancerPartie(ArrayList<String>, double, ArrayList<Role>) : void
        + verifierEtTerminer() : void
        + mettreAJourAffichage() : void
        + getModeActuel() : ModeAction
        + getModele() : Desert
        + getFenetre() : Fenetre
    }
}

' ==================================================================
' CLASSE MAIN
' ==================================================================
class Main {
    + {static} main(String[]) : void
}

' ==================================================================
' RELATIONS - Modele interne
' ==================================================================

' Enums internes
CarteTempete +-- TypeCarteTempete
Equipement +-- TypeEquipement
Piece +-- TypePiece
Controleur +-- ModeAction

' Associations modele
Desert "1" *-- "25" Zone : grille
Desert "1" *-- "1..*" Joueur : joueurs
Desert "1" o-- "*" CarteTempete : piocheTempete
Desert "1" o-- "*" Equipement : piocheEquipement
Zone "1" --> "1" TypeZone : type
Zone "1" o-- "*" Joueur : occupants
Joueur "1" --> "0..1" Role : role
Joueur "1" o-- "*" Equipement : equipements
CarteTempete --> TypeCarteTempete : type
Equipement --> TypeEquipement : type
Piece --> TypePiece : type

' ==================================================================
' RELATIONS - MVC
' ==================================================================

' Vue observe le Modele
Desert <.. VuePlateau : observe
Desert <.. VueJoueurs : observe
Desert <.. VuePieces : observe
Desert <.. VueActions : observe

' Fenetre contient les vues
Fenetre "1" *-- "1" VuePlateau
Fenetre "1" *-- "1" VueJoueurs
Fenetre "1" *-- "1" VuePieces
Fenetre "1" *-- "1" VueActions
Fenetre "1" *-- "1" VueMenu
Fenetre "1" *-- "1" VueFinDePartie

' Controleur relie tout
Controleur "1" --> "1" Desert : modele
Controleur "1" --> "1" Fenetre : fenetre
VuePlateau --> PlateauListener : listener

' Main cree le tout
Main ..> Desert : cree
Main ..> Fenetre : cree
Main ..> Controleur : cree

@enduml
