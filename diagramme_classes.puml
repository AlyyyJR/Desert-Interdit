@startuml diagramme_classes
' ==================================================================
' DIAGRAMME DE CLASSES - Le Desert Interdit
' Auteur : Aly KONATE & Youssef ABOU HASHISH - L2 Informatique
' ==================================================================

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam classAttributeFontSize 10
skinparam classStereotypeFontSize 9
skinparam packageFontSize 13
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50
skinparam dpi 150

' ==================================================================
' PACKAGE MODELE
' ==================================================================
package "modele" #FFF8E1 {

    enum Role {
        ARCHEOLOGUE
        ALPINISTE
        EXPLORATEUR
        METEOROLOGUE
        NAVIGATRICE
        PORTEUSE_EAU
        --
        - nom : String
        - description : String
        --
        + getNom() : String
        + getDescription() : String
    }

    enum TypeZone {
        NORMAL
        OEIL
        CRASH
        PISTE
        OASIS
        MIRAGE
        TUNNEL
        INDICE_LIGNE_0
        INDICE_LIGNE_1
        INDICE_LIGNE_2
        INDICE_LIGNE_3
        INDICE_COLONNE_0
        INDICE_COLONNE_1
        INDICE_COLONNE_2
        INDICE_COLONNE_3
        EQUIPEMENT
        --
        - nom : String
        --
        + getNom() : String
        + isPieceIndice() : boolean
        + getPieceIndex() : int
        + isLigne() : boolean
    }

    class CarteTempete {
        - type : TypeCarteTempete
        - direction : int
        - force : int
        --
        + CarteTempete(TypeCarteTempete, int, int)
        + CarteTempete(TypeCarteTempete)
        + getType() : TypeCarteTempete
        + getDirection() : int
        + getForce() : int
        + getNomDirection() : String
        + toString() : String
    }

    enum "CarteTempete.TypeCarteTempete" as TypeCarteTempete {
        VENT
        CHALEUR
        DECHAINE
    }

    class Equipement {
        - type : TypeEquipement
        --
        + Equipement(TypeEquipement)
        + getType() : TypeEquipement
        + getNom() : String
        + getDescription() : String
        + toString() : String
    }

    enum "Equipement.TypeEquipement" as TypeEquipement {
        JETPACK
        BOUCLIER_SOLAIRE
        BLASTER
        DETECTEUR
        --
        - nom : String
        - description : String
        --
        + getNom() : String
        + getDescription() : String
    }

    class Piece {
        - type : TypePiece
        --
        + Piece(TypePiece)
        + getType() : TypePiece
        + getNom() : String
        + getIndex() : int
        + toString() : String
    }

    enum "Piece.TypePiece" as TypePiece {
        MOTEUR
        HELICE
        GOUVERNAIL
        CAPTEUR
        --
        - nom : String
        - index : int
        --
        + getNom() : String
        + getIndex() : int
    }

    class Zone {
        - ligne : int
        - colonne : int
        - sable : int
        - exploree : boolean
        - type : TypeZone
        - visible : boolean
        - occupants : ArrayList<Joueur>
        --
        + Zone(int, int, TypeZone)
        + addSable() : void
        + retirerSable() : boolean
        + explorer() : boolean
        + isBloquee() : boolean
        + addOccupant(Joueur) : void
        + removeOccupant(Joueur) : void
        + aDesOccupants() : boolean
        + getPiece() : Piece
        + getJoueurs() : ArrayList<Joueur>
        + toString() : String
        .. Getters / Setters ..
        + getLigne() : int
        + setLigne(int) : void
        + getColonne() : int
        + setColonne(int) : void
        + getSable() : int
        + setSable(int) : void
        + isExploree() : boolean
        + setExploree(boolean) : void
        + getType() : TypeZone
        + setType(TypeZone) : void
        + isVisible() : boolean
        + setVisible(boolean) : void
        + getOccupants() : ArrayList<Joueur>
    }

    class Joueur {
        + {static} EAU_MAX : int = 5
        --
        - nom : String
        - ligne : int
        - colonne : int
        - eau : int
        - couleur : Color
        - equipements : ArrayList<Equipement>
        - role : Role
        - index : int
        --
        + Joueur(String, Color)
        + Joueur(String, Color, Role)
        + boireEau() : boolean
        + remplirEau(int) : void
        + estMort() : boolean
        + addEquipement(Equipement) : void
        + removeEquipement(Equipement) : boolean
        + getNumero() : int
        + toString() : String
        .. Getters / Setters ..
        + getNom() : String
        + setNom(String) : void
        + getLigne() : int
        + setLigne(int) : void
        + getColonne() : int
        + setColonne(int) : void
        + getEau() : int
        + setEau(int) : void
        + getCouleur() : Color
        + setCouleur(Color) : void
        + getEquipements() : ArrayList<Equipement>
        + getRole() : Role
        + setRole(Role) : void
        + getIndex() : int
        + setIndex(int) : void
    }

    class Desert <<Observable>> {
        + {static} TAILLE : int = 5
        + {static} SABLE_MAX : int = 48
        + {static} ACTIONS_MAX : int = 4
        + {static} NB_PIECES : int = 4
        --
        - grille : Zone[][]
        - oeilLigne : int
        - oeilColonne : int
        - niveauTempete : double
        - sableTotal : int
        - joueurs : ArrayList<Joueur>
        - joueurActif : Joueur
        - indexJoueurActif : int
        - actionsRestantes : int
        - indicesDecouverts : boolean[][]
        - pieceLigne : int[]
        - pieceColonne : int[]
        - piecesRamassees : boolean[]
        - partieTerminee : boolean
        - partieGagnee : boolean
        - piocheEquipement : ArrayList<Equipement>
        - piocheTempete : ArrayList<CarteTempete>
        - defausseTempete : ArrayList<CarteTempete>
        - random : Random
        - modeDemo : boolean
        --
        + Desert()
        - initGrille() : void
        - creerPiocheEquipement() : void
        - creerPiocheTempete() : void
        + ajouterJoueur(String) : Joueur
        + joueurSuivant() : void
        + deplacerJoueur(Joueur, int, int) : boolean
        + isDeplacementValide(Joueur, int, int) : boolean
        + creuser(Joueur, int, int) : boolean
        + explorer(Joueur) : boolean
        - appliquerEffetZone(Zone, Joueur) : void
        + ramasserPiece(Joueur) : boolean
        + donnerEau(Joueur, Joueur) : boolean
        + donnerEau(Joueur, Joueur, int) : boolean
        + prendreEau(Joueur, Joueur) : boolean
        + prendreEau(Joueur, Joueur, int) : boolean
        + finDeTour() : void
        + actionsDuDesert() : void
        - appliquerCarteTempete(CarteTempete) : void
        + soufflerVent(int, int) : void
        - mettreAJourIndicesPieces() : void
        + vagueDeChaleur() : void
        + tempeteSeDechaine() : void
        + verifierFinDePartie() : void
        + getZonesAdjacentes(int, int) : ArrayList<Zone>
        + getPiecesRestantes() : int
        + pieceDisponible(int, int) : boolean
        - notifierObservateurs() : void
        .. Alias Controleur ..
        + initialiserPartie() : void
        + lancerPartie() : void
        + isPartieFinie() : boolean
        + isVictoire() : boolean
        + getRaisonFinPartie() : String
        + getJoueurCourant() : Joueur
        + decrementerActions() : void
        + reinitialiserActions() : void
        + retirerSable(Joueur, int, int) : boolean
        + explorerZone(Joueur) : boolean
        + getZonesAccessibles(Joueur) : ArrayList
        + getZonesCreusables(Joueur) : ArrayList
        + getZoneJoueur(Joueur) : Zone
        + getJoueursSurZone(int, int) : ArrayList
        + utiliserEquipementSurZone(Joueur, int, int) : boolean
        + preparerEquipement(Joueur) : boolean
        + utiliserEquipement(Joueur, Equipement) : boolean
        + getPiecesRecuperees() : boolean[]
        .. Getters / Setters ..
        + getGrille() : Zone[][]
        + getZone(int, int) : Zone
        + getOeilLigne() : int
        + getOeilColonne() : int
        + getNiveauTempete() : double
        + setNiveauTempete(double) : void
        + isModeDemo() : boolean
        + setModeDemo(boolean) : void
        + getSableTotal() : int
        + getJoueurs() : ArrayList<Joueur>
        + getJoueurActif() : Joueur
        + getActionsRestantes() : int
        + setActionsRestantes(int) : void
        + getIndicesDecouverts() : boolean[][]
        + getPieceLigne() : int[]
        + getPieceColonne() : int[]
        + getPiecesRamassees() : boolean[]
        + isPartieTerminee() : boolean
        + isPartieGagnee() : boolean
        + getPiocheEquipement() : ArrayList
        + getPiocheTempete() : ArrayList
        + getDefausseTempete() : ArrayList
        + getRandom() : Random
    }
}

' ==================================================================
' PACKAGE VUE
' ==================================================================
package "vue" #E3F2FD {

    interface PlateauListener {
        + zoneCliquee(int, int) : void
    }

    class VuePlateau <<JPanel, Observer>> {
        - {static} TAILLE_TUILE : int = 120
        - {static} MARGE : int = 10
        - {static} TAILLE_GRILLE : int = 5
        - desert : Desert
        - zonesSurlignees : ArrayList<int[]>
        - plateauListener : PlateauListener
        - cacheImages : HashMap<String, Image>
        - {static} COULEURS_JOUEURS : Color[]
        --
        + VuePlateau(Desert)
        + VuePlateau()
        + setDesert(Desert) : void
        - chargerImages() : void
        - getImage(String) : Image
        + setPlateauListener(PlateauListener) : void
        + surlignerZones(ArrayList) : void
        + effacerSurlignage() : void
        + effacerSurbrillance() : void
        + update(Observable, Object) : void
        # paintComponent(Graphics) : void
        - dessinerPlateauVide(Graphics2D) : void
        - dessinerZone(Graphics2D, Zone, int, int) : void
        - dessinerFondZone(Graphics2D, Zone, int, int) : void
        - dessinerIconeZone(Graphics2D, Zone, int, int) : void
        - dessinerSable(Graphics2D, Zone, int, int) : void
        - dessinerPieceSurZone(Graphics2D, int, int) : void
        - dessinerJoueurs(Graphics2D, Zone, int, int) : void
        - dessinerSurlignages(Graphics2D) : void
        - dessinerTexteCentre(Graphics2D, String, int, int, int) : void
        + getTailleTuile() : int
        + getMarge() : int
    }

    class VueJoueurs <<JPanel, Observer>> {
        - panneauJoueurs : JPanel
        - cacheImagesRoles : HashMap<String, ImageIcon>
        - {static} COULEURS_JOUEURS : Color[]
        --
        + VueJoueurs()
        + mettreAJour(ArrayList<Joueur>, Joueur) : void
        - creerCarteJoueur(Joueur, int, boolean) : JPanel
        - nomImageRole(Role) : String
        + update(Observable, Object) : void
    }

    class VuePieces <<JPanel, Observer>> {
        - {static} NOMS_PIECES : String[]
        - piecesRecuperees : boolean[]
        - labelsPieces : JLabel[]
        --
        + VuePieces()
        + mettreAJour(boolean[]) : void
        + update(Observable, Object) : void
